import mysql.connector
import hashlib
from getpass import getpass

admin_username = "your_name"
admin_password = "your_password"

try:
    database = mysql.connector.connect(
        host="localhost",
        user="root",
        password="your_password",
        database="Library"
    )
except mysql.connector.Error as err:
    print(f"Database connection error: {err}")
    raise SystemExit

remote = database.cursor()

remote.execute("""
CREATE TABLE IF NOT EXISTS Books(
    Book_ID INT PRIMARY KEY AUTO_INCREMENT,
    Book_name VARCHAR(200) NOT NULL,
    Author_name VARCHAR(100) NOT NULL,
    No_of_books INT NOT NULL DEFAULT 0
)
""")
remote.execute("""
CREATE TABLE IF NOT EXISTS Customers(
    Customer_ID INT PRIMARY KEY AUTO_INCREMENT,
    Name VARCHAR(100) NOT NULL,
    DATE_OF_BIRTH DATE,
    Password VARCHAR(64) NOT NULL
)
""")
remote.execute("""
CREATE TABLE IF NOT EXISTS Issued_books(
    Issued_ID INT PRIMARY KEY AUTO_INCREMENT,
    Book_ID INT NOT NULL,
    Customer_ID INT,
    Taken_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (Book_ID) REFERENCES Books(Book_ID)
)
""")
remote.execute("""
CREATE TABLE IF NOT EXISTS Customer_data(
    Log_ID INT AUTO_INCREMENT PRIMARY KEY,
    username VARCHAR(100) NOT NULL,
    Status VARCHAR(30),
    DATE_AND_TIME TIMESTAMP DEFAULT CURRENT_TIMESTAMP
)
""")
database.commit()


def hash_password(password):
    return hashlib.sha256(password.encode()).hexdigest()


def add_book():
    book_name = input("Enter the name of the book: ").strip()
    author_name = input("Enter the name of the author: ").strip()
    no_of_books = int(input("Enter the number of books: "))

    remote.execute(
        "INSERT INTO Books (Book_name, Author_name, No_of_books) VALUES (%s, %s, %s)",
        (book_name, author_name, no_of_books)
    )
    database.commit()
    print(f"Book '{book_name}' by {author_name} added successfully.")


def remove_book():
    book_name = input("Enter the name of the book to remove: ").strip()
    remote.execute("DELETE FROM Books WHERE Book_name = %s", (book_name,))
    database.commit()

    if remote.rowcount > 0:
        print(f"Book '{book_name}' removed successfully.")
    else:
        print(f"Book '{book_name}' not found.")


def show_books():
    remote.execute("SELECT * FROM Books")
    books = remote.fetchall()
    print("=" * 50)
    print("Books in the library:")
    for book in books:
        print(f"ID: {book[0]}, Name: {book[1]}, Author: {book[2]}, Quantity: {book[3]}")


def borrow_book():
    book_name = input("Enter the name of the book you want to borrow: ").strip()
    remote.execute("SELECT Book_ID, No_of_books FROM Books WHERE Book_name = %s", (book_name,))
    book = remote.fetchone()

    if book is None:
        print(f"Book '{book_name}' not found in the library.")
        return

    if book[1] > 0:
        remote.execute(
            "INSERT INTO Issued_books (Book_ID) VALUES (%s)",
            (book[0],)
        )
        remote.execute(
            "UPDATE Books SET No_of_books = No_of_books - 1 WHERE Book_ID = %s",
            (book[0],)
        )
        database.commit()
        print(f"Book '{book_name}' issued successfully.")
    else:
        print(f"Book '{book_name}' is currently not available.")


def return_book():
    book_name = input("Enter the name of the book you want to return: ").strip()

    remote.execute("SELECT Book_ID FROM Books WHERE Book_name = %s", (book_name,))
    book = remote.fetchone()

    if book is None:
        print(f"Book '{book_name}' not found in the library.")
        return

    book_id = book[0]

    remote.execute(
        "SELECT Issued_ID FROM Issued_books WHERE Book_ID = %s ORDER BY Taken_at DESC LIMIT 1",
        (book_id,)
    )
    issued = remote.fetchone()

    if issued is None:
        print(f"No issued record found for '{book_name}'.")
        return

    remote.execute("DELETE FROM Issued_books WHERE Issued_ID = %s", (issued[0],))
    remote.execute(
        "UPDATE Books SET No_of_books = No_of_books + 1 WHERE Book_ID = %s",
        (book_id,)
    )
    database.commit()
    print(f"Book '{book_name}' returned successfully.")


def registration():
    name = input("Enter your name: ").strip()
    password1 = getpass("Enter your password: ")
    dob = input("Enter your date of birth (YYYY-MM-DD): ").strip()

    hashed_password = hash_password(password1)

    remote.execute(
        "INSERT INTO Customers (Name, Password, DATE_OF_BIRTH) VALUES (%s, %s, %s)",
        (name, hashed_password, dob)
    )
    database.commit()
    print(f"Customer '{name}' registered successfully.")


def update_book_quantity():
    book_name = input("Enter the name of the book: ").strip()
    new_quantity = int(input("Enter the new quantity: "))

    remote.execute(
        "UPDATE Books SET No_of_books = %s WHERE Book_name = %s",
        (new_quantity, book_name)
    )
    database.commit()

    if remote.rowcount > 0:
        print(f"Quantity of '{book_name}' updated successfully to {new_quantity}.")
    else:
        print(f"Book '{book_name}' not found.")


def log_in(username):
    remote.execute(
        "INSERT INTO Customer_data(username, Status) VALUES (%s, %s)",
        (username, "Customer logged in")
    )
    database.commit()


def log_out(username):
    remote.execute(
        "INSERT INTO Customer_data(username, Status) VALUES (%s, %s)",
        (username, "Customer logged out")
    )
    database.commit()


def admin_login():
    username = input("Enter admin username: ").strip()
    password = getpass("Enter admin password: ")

    if username == admin_username and password == admin_password:
        print("Admin login successful.")
        while True:
            print("-" * 50)
            print("Admin Menu:")
            print("-" * 50)
            print("1. Add Book")
            print("2. Remove Book")
            print("3. Show Books")
            print("4. Update Book Quantity")
            print("5. Customer Data")
            print("6. Log out")

            choice = input("Enter your choice: ").strip()

            if choice == '1':
                add_book()
            elif choice == '2':
                remove_book()
            elif choice == '3':
                show_books()
            elif choice == '4':
                update_book_quantity()
            elif choice == '5':
                remote.execute("SELECT * FROM Customer_data ORDER BY DATE_AND_TIME DESC")
                result = remote.fetchall()
                for row in result:
                    print(row)
            elif choice == '6':
                print("Logging out...")
                break
            else:
                print("Invalid choice. Please try again.")
    else:
        print("Invalid admin credentials.")


def customer_login():
    username = input("Enter your name: ").strip()
    password1 = getpass("Enter your password: ")
    hashed = hash_password(password1)

    remote.execute(
        "SELECT * FROM Customers WHERE Name = %s AND Password = %s",
        (username, hashed)
    )
    result = remote.fetchone()

    if result is None:
        print("Invalid credentials. Please register or try again.")
        return

    log_in(username)
    print("Successfully logged in!")

    while True:
        print("-" * 50)
        print("Customer Menu:")
        print("-" * 50)
        print("1. Borrow Book")
        print("2. Return Book")
        print("3. Show Books")
        print("4. Log out")

        choice = input("Enter your choice: ").strip()

        if choice == '1':
            borrow_book()
        elif choice == '2':
            return_book()
        elif choice == '3':
            show_books()
        elif choice == '4':
            log_out(username)
            print("Logging out...")
            break
        else:
            print("Invalid choice. Please try again.")


while True:
    print("-" * 50)
    print("Library Management System")
    print("-" * 50)
    print("1. Admin Login")
    print("2. Customer Login")
    print("3. Customer Registration")
    print("4. Exit")

    try:
        choice = int(input("Enter your choice: "))
    except ValueError:
        print("Please enter a valid number.")
        continue

    if choice == 1:
        admin_login()
    elif choice == 2:
        customer_login()
    elif choice == 3:
        registration()
    elif choice == 4:
        break
    else:
        print("Invalid choice.")

remote.close()
database.close()
print("Thank you for using our library system. Visit again!")
